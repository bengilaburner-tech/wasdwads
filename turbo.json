{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".output/**", ".vinxi/**", ".tanstack/**", "generated/**"],
			"cache": true
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": [],
			"outputs": [],
			"cache": true
		},
		"typecheck": {
			"dependsOn": [],
			"outputs": [],
			"cache": true
		},
		"test": {
			"dependsOn": [],
			"outputs": ["coverage/**"],
			"cache": true
		},
		"test:unit": {
			"dependsOn": [],
			"outputs": ["coverage/**"],
			"cache": true
		},
		"test:integration": {
			"dependsOn": [],
			"outputs": ["coverage/**"],
			"cache": true
		},
		"test:e2e": {
			"dependsOn": [],
			"outputs": [],
			"cache": false,
			"persistent": true
		},
		"proto:generate": {
			"dependsOn": [],
			"outputs": ["generated/**"],
			"cache": true
		},
		"db:generate": {
			"dependsOn": [],
			"cache": false
		},
		"db:migrate": {
			"dependsOn": [],
			"cache": false
		},
		"db:seed": {
			"dependsOn": ["db:migrate"],
			"cache": false
		}
	},
	"globalEnv": ["NODE_ENV"],
	"globalPassThroughEnv": ["DATABASE_URL"]
}
