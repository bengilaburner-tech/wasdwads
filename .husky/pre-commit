#!/bin/sh

# Pre-commit hook: validate staged changes
# Runs type checking and linting on changed files
# Blocks commit if checks fail

set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "🔍 Pre-commit checks..."

# Type check
echo "📝 Type checking staged files..."
pnpm turbo run typecheck --filter='[HEAD]' --no-cache

# Lint
echo "🧹 Linting staged files..."
pnpm turbo run lint --filter='[HEAD]' --no-cache

echo "✅ Pre-commit checks passed"
